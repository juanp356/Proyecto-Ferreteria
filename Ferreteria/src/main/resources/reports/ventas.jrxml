<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN" "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ventas" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="50" bottomMargin="50" uuid="ventas-uuid-001">

    <parameter name="titulo" class="java.lang.String"/>
    <!-- Ruta relativa al proyecto; coloca FerrePro.png en src/main/resources/static/images/ -->
    <parameter name="logoPath" class="java.lang.String"/>

    <field name="id" class="java.lang.Long"/>
    <field name="fecha" class="java.time.LocalDate"/>
    <field name="cliente" class="java.lang.String"/>
    <field name="producto" class="java.lang.String"/>
    <field name="cantidad" class="java.lang.Integer"/>
    <field name="total" class="java.lang.Double"/>

    <style name="Title" fontSize="18" isBold="true"/>
    <style name="Header" backcolor="#F5F7F9" forecolor="#333333" mode="Opaque"/>
    <style name="Row"/>
    <style name="AltRow" backcolor="#FAFAFA"/>

    <background>
        <band splitType="Stretch"/>
    </background>

    <title>
        <band height="80">
            <image>
                <reportElement x="0" y="0" width="80" height="40"/>
                <imageExpression><![CDATA[new java.io.File($P{logoPath}).exists() ? $P{logoPath} : null]]></imageExpression>
            </image>

            <textField>
                <reportElement x="100" y="0" width="400" height="30"/>
                <textElement>
                    <font size="20" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>

            <textField pattern="dd/MM/yyyy">
                <reportElement x="100" y="30" width="200" height="20"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <frame>
                <reportElement x="0" y="0" width="515" height="25"/>
                <!-- Encabezados -->
                <staticText>
                    <reportElement x="0" y="0" width="80" height="25" style="Header"/>
                    <textElement textAlignment="Center"/>
                    <text><![CDATA[Fecha]]></text>
                </staticText>
                <staticText>
                    <reportElement x="80" y="0" width="160" height="25" style="Header"/>
                    <textElement textAlignment="Center"/>
                    <text><![CDATA[Cliente]]></text>
                </staticText>
                <staticText>
                    <reportElement x="240" y="0" width="140" height="25" style="Header"/>
                    <textElement textAlignment="Center"/>
                    <text><![CDATA[Producto]]></text>
                </staticText>
                <staticText>
                    <reportElement x="380" y="0" width="60" height="25" style="Header"/>
                    <textElement textAlignment="Center"/>
                    <text><![CDATA[Cant.]]></text>
                </staticText>
                <staticText>
                    <reportElement x="440" y="0" width="75" height="25" style="Header"/>
                    <textElement textAlignment="Center"/>
                    <text><![CDATA[Total]]></text>
                </staticText>
            </frame>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="80" height="20"/>
                <textFieldExpression><![CDATA[$F{fecha}.toString()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="160" height="20"/>
                <textFieldExpression><![CDATA[$F{cliente}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="240" y="0" width="140" height="20"/>
                <textFieldExpression><![CDATA[$F{producto}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="60" height="20"/>
                <textFieldExpression><![CDATA[String.valueOf($F{cantidad})]]></textFieldExpression>
            </textField>
            <textField pattern=","2">
            <reportElement x="440" y="0" width="75" height="20"/>
            <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
        </textField>
    </band>
</detail>

<pageFooter>
<band height="30">
    <textField>
        <reportElement x="0" y="5" width="300" height="20"/>
        <textFieldExpression><![CDATA["Generado: " + new java.util.Date()]]></textFieldExpression>
    </textField>
    <textField>
        <reportElement x="400" y="5" width="115" height="20"/>
        <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
    </textField>
</band>
</pageFooter>
        </jasperReport>